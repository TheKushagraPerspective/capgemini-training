package com.capg.map;

import java.util.HashMap;
import java.util.Map;

public class MapDemo {
	public static void main(String []args) {
		System.out.println("----- HASHMAP DEMO -----");

        HashMap<Integer, String> map = new HashMap<>();
        
        map.put(1 , "A");
        map.put(2 , "B");
        map.put(3 , "C");
        
        System.out.println(map);
        
     // duplicate key (overwrite)
        map.put(2, "BB");

        // null key & value
        map.put(null, "NULL_KEY");
        map.put(4, null);

        System.out.println("HashMap: " + map);
        
     // get()
        System.out.println("Get key 2: " + map.get(2));

        // remove()
        map.remove(3);
        System.out.println("After remove: " + map);
        
     // containsKey() & containsValue()
        System.out.println("Contains key 1? " + map.containsKey(1));
        System.out.println("Contains value 'A'? " + map.containsValue("A"));

        // size()
        System.out.println("Size: " + map.size());

        // isEmpty()
        System.out.println("Is Empty? " + map.isEmpty());
        
        System.out.println("\n--- Iteration: entrySet (BEST) ---");
        for(Map.Entry<Integer , String> entry : map.entrySet()) {
        	System.out.println(entry.getKey() + " " + entry.getValue());
        }
        
        System.out.println("\n--- Iteration: keySet ---");
        for(Integer key : map.keySet()) {
        	System.out.println(key);
        }
        
        System.out.println("\n--- Iteration: Value ---");
        for(String value : map.values()) {
        	System.out.println(value);
        }
        
	}
}
