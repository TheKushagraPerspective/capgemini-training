package com.capg.questions;

import java.util.Scanner;

public class TransactionLogValidation {
	 public static void main(String[] args) {
		 Scanner sc = new Scanner(System.in);
		 
		 int n = sc.nextInt();
		 
		 while(n-- > 0) {
			 String log = sc.nextLine();
			 
			 String []parts = log.split("\\|");
			 
			 String txnId = parts[0];
			 String date = parts[1];
			 String currency = parts[2];
			 String amount = parts[3];
			 String status = parts[4];
			 
			 if(validateTransactionId(txnId) && 
					 validateDate(date) && 
					 validateCurrency(currency) && 
					 validateAmount(amount) &&
		             validateStatus(status)) {
				 System.out.println("VALID LOG");
			 }
			 else {
				 System.out.println("INVALID LOG");
			 }
		 }
	 }
	 
	 public static boolean validateTransactionId(String txnId) {
		 if(!txnId.startsWith("TXN-")) return false;
		 
		 String num = txnId.substring(4);
		 
		 if(num.length() != 6) return false;
		 
		 for(char ch : num.toCharArray()) {
			 if(!Character.isDigit(ch)) {
				 return false;
			 }
		 }
		 
		 int count = 1;
		 for(int i=1 ; i<num.length() ; i++) {
			 if(num.charAt(i) == num.charAt(i-1)) {
				 count++;
			 }
			 else {
				 count = 1;
			 }
			 
			 if(count >= 3) {
				 return false;
			 }
		 }
		 
		 return true;
	 }
	 
	 public static boolean validateDate(String date) {
		 String []d = date.split("-");
		 
		 if(d.length != 3) return false;
		 
		 int year = Integer.parseInt(d[0]);
		 int month = Integer.parseInt(d[1]);
		 int day = Integer.parseInt(d[2]);
		 
		 if(year < 2000 || year > 2009) return false;
		 if(month < 1 || month > 12) return false;
		 
		 int maxDays = 31;
		 
		 if(month == 4 || month == 6 || month == 9 || month == 11) {
			 maxDays = 30;
		 }
		 else if(month == 2) {
			 if((year % 4 == 0 && year % 100 != 0) || year % 400 == 0) {
				 maxDays = 29;
			 }
			 else {
				 maxDays = 28;
			 }
		 }
		 
		 if(day < 0 || day > maxDays) return false;
		 
		 return true;
	 }
	 
	 public static boolean validateCurrency(String currency) {
		 return currency.equals("INR") ||
	               currency.equals("USD") ||
	               currency.equals("EUR") ||
	               currency.equals("GBP") ||
	               currency.equals("JPY") ||
	               currency.equals("AUD");
	 }
	 
	 public static boolean validateAmount(String amount) {
		 if(amount.startsWith("0"));
		 
		 try {
			 double val = Double.parseDouble(amount);
			 
			 if(val <= 0) return false;
		 }
		 catch(Exception e) {
			 return false;
		 }
		 
		 return true;
	 }
	 
	 public static boolean validateStatus(String status) {
		 return status.equals("SUCCESS") ||
	               status.equals("FAILED") ||
	               status.equals("PENDING");
	    }
	 }
}
