package com.capg.set;

import java.util.HashSet;

public class SetDemo {
	public static void main(String[] arg) {
		 System.out.println("----- HASHSET DEMO -----");

        HashSet<Integer> hs = new HashSet<>();
        
        hs.add(10);
        hs.add(30);
        hs.add(20);
        hs.add(30);   // ignored
        System.out.println(hs);
	}
}
