				 System.out.println("VALID LOG");
			 }
			 else {
				 System.out.println("INVALID LOG");
			 }
		 }
	 }
	 
	 public static boolean validateTransactionId(String txnId) {
		 if(!txnId.startsWith("TXN-")) return false;
		 
		 String num = txnId.substring(4);
		 
		 if(num.length() != 6) return false;
		 
		 for(char ch : num.toCharArray()) {
			 if(!Character.isDigit(ch)) {
				 return false;
			 }
		 }
		 
		 int count = 1;
		 for(int i=1 ; i<num.length() ; i++) {
			 if(num.charAt(i) == num.charAt(i-1)) {
				 count++;
			 }
			 else {
				 count = 1;
			 }
			 
			 if(count >= 3) {
				 return false;
			 }
		 }
		 
		 return true;
	 }
	 
